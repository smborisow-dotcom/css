---
layout: layouts/base.njk
---

<section class="section">
  <div class="section__head">
    <div>
      <h1>{{ title }}</h1>
      {% if metaDescription %}<p>{{ metaDescription }}</p>{% endif %}
    </div>
    <a class="btn" href="/catalog/">Каталог</a>
  </div>

  <div class="list">
    {% set items = (collections.product | whereTruthy("data.oldPrice") | sortBy("data.productName")) %}
    {% for p in items %}
      <div class="productRow">
        <div>
          <a href="{{ p.url }}" class="productRow__title">{{ p.data.productName }}</a>
          <div class="productRow__sub">{{ p.data.categoryName }}</div>
          {% if p.data.sizes %}<div class="productRow__sub">{{ p.data.sizes }}</div>{% endif %}
        </div>
        <div class="price">
          <s>{{ p.data.oldPrice }}</s>
          {{ p.data.price }}
        </div>
      </div>
    {% endfor %}

    {% if items.length == 0 %}
      <div class="content">
        <p>Товары со скидками появятся после импорта контента.</p>
      </div>
    {% endif %}
  </div>
</section>

{% if content and content | trim %}
  <section class="section">
    <div class="content">
      {{ content | safe }}
    </div>
  </section>
{% endif %}

