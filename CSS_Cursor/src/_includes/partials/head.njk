{% set title = metaTitle or title or site.name %}
{% set description = metaDescription or description or "" %}
{% set baseUrl = env.SITE_URL or site.url %}
<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{{ title | safe }}</title>
    {% if description %}<meta name="description" content="{{ description | striptags | safe }}" />{% endif %}
    <link rel="canonical" href="{{ baseUrl }}{{ page.url }}" />
    <link rel="stylesheet" href="/assets/css/styles.css" />
    <meta name="theme-color" content="#0b1220" />
  </head>
